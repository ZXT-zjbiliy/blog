---
import "@styles/global.css";
import { sitePath } from "@lib/site-data";

const {
  title = "ZXT Notes",
  description = "Personal notes, projects, and topics."
} = Astro.props;

const pageTitle = title === "ZXT Notes" ? title : `${title} | ZXT Notes`;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href={sitePath("/favicon.svg")} />
    <script is:inline>
      (() => {
        const savedLanguage = localStorage.getItem("zxt-language");
        const language = savedLanguage === "zh" ? "zh" : "en";
        document.documentElement.dataset.lang = language;
        document.documentElement.lang = language === "zh" ? "zh-CN" : "en";
      })();
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      (() => {
        const key = "zxt-language";
        const root = document.documentElement;

        function currentLanguage() {
          return localStorage.getItem(key) === "zh" ? "zh" : "en";
        }

        function applyLanguage(language) {
          root.dataset.lang = language;
          root.lang = language === "zh" ? "zh-CN" : "en";
          localStorage.setItem(key, language);

          for (const element of document.querySelectorAll("[data-zh]")) {
            if (!element.dataset.en) {
              element.dataset.en = element.textContent ?? "";
            }

            element.textContent = language === "zh" ? element.dataset.zh ?? "" : element.dataset.en;
          }

          for (const element of document.querySelectorAll("[data-placeholder-zh]")) {
            if (element instanceof HTMLInputElement) {
              element.dataset.placeholderEn ||= element.placeholder;
              element.placeholder =
                language === "zh" ? element.dataset.placeholderZh ?? element.placeholder : element.dataset.placeholderEn;
            }
          }

          for (const toggle of document.querySelectorAll("[data-language-toggle]")) {
            if (toggle instanceof HTMLButtonElement) {
              toggle.setAttribute("aria-pressed", String(language === "zh"));
              toggle.setAttribute("aria-label", language === "zh" ? "Switch to English" : "切换到中文");
            }
          }
        }

        const noteViewsKey = "zxt-note-views";

        function readNoteViews() {
          try {
            return JSON.parse(localStorage.getItem(noteViewsKey) ?? "{}");
          } catch {
            return {};
          }
        }

        function writeNoteViews(views) {
          localStorage.setItem(noteViewsKey, JSON.stringify(views));
        }

        function noteViewLabel(count, language) {
          return language === "zh" ? `${count} 次点击` : `${count} views`;
        }

        function noteIdForElement(element) {
          const owner = element.closest("[data-note-id]");
          return owner instanceof HTMLElement ? owner.dataset.noteId : undefined;
        }

        function updateNoteViewDisplays(views) {
          const language = currentLanguage();

          for (const counter of document.querySelectorAll("[data-note-view-count]")) {
            if (!(counter instanceof HTMLElement)) {
              continue;
            }

            const noteId = noteIdForElement(counter);
            const count = noteId ? Number(views[noteId] ?? 0) : 0;
            counter.dataset.en = noteViewLabel(count, "en");
            counter.dataset.zh = noteViewLabel(count, "zh");
            counter.textContent = noteViewLabel(count, language);
          }
        }

        function sortNoteCardsByViews(views) {
          for (const container of document.querySelectorAll("[data-sort-notes-by-views]")) {
            const cards = Array.from(container.children).filter(
              (child) => child instanceof HTMLElement && child.matches("[data-note-card]")
            );

            cards.forEach((card, index) => {
              card.dataset.originalIndex ||= String(index);
            });

            cards
              .sort((left, right) => {
                const leftViews = Number(views[left.dataset.noteId ?? ""] ?? 0);
                const rightViews = Number(views[right.dataset.noteId ?? ""] ?? 0);

                if (leftViews !== rightViews) {
                  return rightViews - leftViews;
                }

                return Number(left.dataset.originalIndex ?? 0) - Number(right.dataset.originalIndex ?? 0);
              })
              .forEach((card) => container.append(card));
          }
        }

        function trackCurrentNoteView(views) {
          const currentNote = document.querySelector("[data-note-view-root][data-note-id]");

          if (!(currentNote instanceof HTMLElement) || !currentNote.dataset.noteId) {
            return views;
          }

          const noteId = currentNote.dataset.noteId;
          views[noteId] = Number(views[noteId] ?? 0) + 1;
          writeNoteViews(views);
          return views;
        }

        applyLanguage(currentLanguage());

        const views = trackCurrentNoteView(readNoteViews());
        updateNoteViewDisplays(views);
        sortNoteCardsByViews(views);

        for (const toggle of document.querySelectorAll("[data-language-toggle]")) {
          toggle.addEventListener("click", () => {
            applyLanguage(currentLanguage() === "zh" ? "en" : "zh");
            updateNoteViewDisplays(readNoteViews());
          });
        }
      })();
    </script>
  </body>
</html>
