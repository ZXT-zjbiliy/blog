---
import "@styles/global.css";
import { sitePath } from "@lib/site-data";

const {
  title = "ZXT Notes",
  description = "Personal notes, projects, and topics."
} = Astro.props;

const pageTitle = title === "ZXT Notes" ? title : `${title} | ZXT Notes`;
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="icon" href={sitePath("/favicon.svg")} />
    <script is:inline>
      (() => {
        const savedLanguage = localStorage.getItem("zxt-language");
        const language = savedLanguage === "zh" ? "zh" : "en";
        document.documentElement.dataset.lang = language;
        document.documentElement.lang = language === "zh" ? "zh-CN" : "en";
      })();
    </script>
    <script is:inline>
      (() => {
        const saved = localStorage.getItem("zxt-theme");
        const theme =
          saved === "dark" || saved === "light"
            ? saved
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
        document.documentElement.dataset.theme = theme;
      })();
    </script>
    <script is:inline>
      (() => {
        if (localStorage.getItem("zxt-rgb") === "on") {
          document.documentElement.dataset.rgb = "on";
        }
      })();
    </script>
  </head>
  <body>
    <div id="fx-aurora" aria-hidden="true"></div>
    <canvas id="fx-canvas" aria-hidden="true"></canvas>
    <slot />
    <script is:inline>
      /* Flashy-mode particle + spark engine. Exposed as window.__fx.{start,stop};
       * BaseLayout's applyRgb() drives it. Zero dependencies. Particle colour
       * reads the live --hue so it flows with the RGB hue cycle. */
      (() => {
        const canvas = document.getElementById("fx-canvas");
        if (!(canvas instanceof HTMLCanvasElement)) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        const root = document.documentElement;
        const reduceMq = window.matchMedia("(prefers-reduced-motion: reduce)");
        const mobileMq = window.matchMedia("(max-width: 768px)");

        let dpr = 1;
        let W = 0;
        let H = 0;
        let particles = [];
        let sparks = [];
        let rafId = 0;
        let running = false;
        let lastTrail = 0;

        function targetCount() {
          const cap = mobileMq.matches ? 40 : 120;
          return Math.min(cap, Math.floor((window.innerWidth * window.innerHeight) / 12000));
        }

        function resize() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          W = canvas.width = Math.floor(window.innerWidth * dpr);
          H = canvas.height = Math.floor(window.innerHeight * dpr);
        }

        function seedParticles() {
          const n = targetCount();
          particles = [];
          for (let i = 0; i < n; i++) {
            particles.push({
              x: Math.random() * W,
              y: Math.random() * H,
              vx: (Math.random() - 0.5) * 0.35 * dpr,
              vy: (Math.random() - 0.5) * 0.35 * dpr
            });
          }
        }

        function hue() {
          const raw = getComputedStyle(root).getPropertyValue("--hue").trim();
          const n = parseFloat(raw);
          return Number.isFinite(n) ? n : 280;
        }

        function frame() {
          if (!running) return;
          const h = hue();
          const dot = "hsl(" + h + " 90% 65%)";
          const linkMax = 120 * dpr;
          ctx.clearRect(0, 0, W, H);

          for (const p of particles) {
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0 || p.x > W) p.vx *= -1;
            if (p.y < 0 || p.y > H) p.vy *= -1;
            ctx.beginPath();
            ctx.arc(p.x, p.y, 2 * dpr, 0, Math.PI * 2);
            ctx.fillStyle = dot;
            ctx.fill();
          }

          for (let i = 0; i < particles.length; i++) {
            for (let j = i + 1; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d2 = dx * dx + dy * dy;
              if (d2 < linkMax * linkMax) {
                ctx.globalAlpha = 1 - Math.sqrt(d2) / linkMax;
                ctx.beginPath();
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.strokeStyle = dot;
                ctx.lineWidth = dpr;
                ctx.stroke();
                ctx.globalAlpha = 1;
              }
            }
          }

          for (let i = sparks.length - 1; i >= 0; i--) {
            const s = sparks[i];
            s.x += s.vx;
            s.y += s.vy;
            s.vy += 0.05 * dpr;
            s.life -= 0.016;
            if (s.life <= 0) {
              sparks.splice(i, 1);
              continue;
            }
            ctx.globalAlpha = Math.max(0, s.life);
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fillStyle = "hsl(" + s.hue + " 95% 62%)";
            ctx.fill();
            ctx.globalAlpha = 1;
          }

          rafId = requestAnimationFrame(frame);
        }

        function addSpark(x, y, spread, count) {
          const base = hue();
          for (let i = 0; i < count; i++) {
            const a = Math.random() * Math.PI * 2;
            const sp = Math.random() * spread * dpr;
            sparks.push({
              x: x * dpr,
              y: y * dpr,
              vx: Math.cos(a) * sp,
              vy: Math.sin(a) * sp,
              r: (1 + Math.random() * 2) * dpr,
              hue: (base + Math.random() * 360) % 360,
              life: 0.6 + Math.random() * 0.5
            });
          }
        }

        function onMove(e) {
          const now = performance.now();
          if (now - lastTrail < 32) return;
          lastTrail = now;
          addSpark(e.clientX, e.clientY, 0.8, 2);
        }

        function onClick(e) {
          addSpark(e.clientX, e.clientY, 6, 26);
        }

        function onVisibility() {
          if (document.hidden) {
            running = false;
            cancelAnimationFrame(rafId);
          } else if (root.dataset.rgb === "on" && !reduceMq.matches) {
            if (!running) {
              running = true;
              frame();
            }
          }
        }

        let active = false;

        function start() {
          if (active) return; // idempotent: already running
          active = true;
          resize();
          seedParticles();
          window.addEventListener("resize", onResize);
          document.addEventListener("visibilitychange", onVisibility);
          if (reduceMq.matches) {
            // Reduced motion: draw a single static frame, no loop, no trails.
            running = true;
            frame();
            running = false;
            return;
          }
          window.addEventListener("mousemove", onMove);
          window.addEventListener("click", onClick);
          if (!running) {
            running = true;
            frame();
          }
        }

        function onResize() {
          resize();
          seedParticles();
        }

        function stop() {
          if (!active) return;
          active = false;
          running = false;
          cancelAnimationFrame(rafId);
          window.removeEventListener("resize", onResize);
          window.removeEventListener("mousemove", onMove);
          window.removeEventListener("click", onClick);
          document.removeEventListener("visibilitychange", onVisibility);
          sparks = [];
          particles = [];
          ctx.clearRect(0, 0, canvas.width, canvas.height);
        }

        window.__fx = { start, stop };
      })();
    </script>
    <script is:inline>
      (() => {
        const key = "zxt-language";
        const root = document.documentElement;

        function currentLanguage() {
          return localStorage.getItem(key) === "zh" ? "zh" : "en";
        }

        function applyLanguage(language) {
          root.dataset.lang = language;
          root.lang = language === "zh" ? "zh-CN" : "en";
          localStorage.setItem(key, language);

          for (const element of document.querySelectorAll("[data-zh]")) {
            if (!element.dataset.en) {
              element.dataset.en = element.textContent ?? "";
            }

            element.textContent = language === "zh" ? element.dataset.zh ?? "" : element.dataset.en;
          }

          for (const element of document.querySelectorAll("[data-placeholder-zh]")) {
            if (element instanceof HTMLInputElement) {
              element.dataset.placeholderEn ||= element.placeholder;
              element.placeholder =
                language === "zh" ? element.dataset.placeholderZh ?? element.placeholder : element.dataset.placeholderEn;
            }
          }

          for (const toggle of document.querySelectorAll("[data-language-toggle]")) {
            if (toggle instanceof HTMLButtonElement) {
              toggle.setAttribute("aria-pressed", String(language === "zh"));
              toggle.setAttribute("aria-label", language === "zh" ? "Switch to English" : "切换到中文");
            }
          }
        }

        const themeKey = "zxt-theme";

        function currentTheme() {
          return root.dataset.theme === "dark" ? "dark" : "light";
        }

        function applyTheme(theme, persist) {
          root.dataset.theme = theme;
          if (persist) {
            localStorage.setItem(themeKey, theme);
          }

          const language = currentLanguage();
          for (const toggle of document.querySelectorAll("[data-theme-toggle]")) {
            if (toggle instanceof HTMLButtonElement) {
              toggle.setAttribute("aria-pressed", String(theme === "dark"));
              const label =
                theme === "dark"
                  ? language === "zh"
                    ? "切换到浅色模式"
                    : "Switch to light theme"
                  : language === "zh"
                    ? "切换到深色模式"
                    : "Switch to dark theme";
              toggle.setAttribute("aria-label", label);
            }
          }
        }

        const rgbKey = "zxt-rgb";

        function rgbOn() {
          return root.dataset.rgb === "on";
        }

        function applyRgb(on, persist) {
          if (on) {
            root.dataset.rgb = "on";
          } else {
            delete root.dataset.rgb;
          }
          if (persist) {
            localStorage.setItem(rgbKey, on ? "on" : "off");
          }

          const language = currentLanguage();
          for (const toggle of document.querySelectorAll("[data-rgb-toggle]")) {
            if (toggle instanceof HTMLButtonElement) {
              toggle.setAttribute("aria-pressed", String(on));
              const label = on
                ? language === "zh"
                  ? "关闭炫酷模式"
                  : "Turn off flashy mode"
                : language === "zh"
                  ? "开启炫酷模式"
                  : "Turn on flashy mode";
              toggle.setAttribute("aria-label", label);
            }
          }

          // Start/stop the particle + spark engine to match the mode.
          if (window.__fx) {
            on ? window.__fx.start() : window.__fx.stop();
          }
        }

        // Online view counter backed by a Cloudflare Worker + KV.
        const viewsApi = "https://blog-views.xt-zhang.workers.dev";
        const viewedKey = "zxt-viewed";

        async function fetchNoteViews() {
          try {
            const res = await fetch(`${viewsApi}/counts`);
            if (!res.ok) return {};
            return await res.json();
          } catch {
            return {};
          }
        }

        function alreadyViewed(noteId) {
          try {
            const seen = JSON.parse(sessionStorage.getItem(viewedKey) ?? "[]");
            return Array.isArray(seen) && seen.includes(noteId);
          } catch {
            return false;
          }
        }

        function markViewed(noteId) {
          try {
            const seen = JSON.parse(sessionStorage.getItem(viewedKey) ?? "[]");
            const next = Array.isArray(seen) ? seen : [];
            if (!next.includes(noteId)) next.push(noteId);
            sessionStorage.setItem(viewedKey, JSON.stringify(next));
          } catch {
            /* ignore storage errors */
          }
        }

        function noteViewLabel(count, language) {
          return language === "zh" ? ` · ${count} 次点击` : ` · ${count} views`;
        }

        function noteIdForElement(element) {
          const owner = element.closest("[data-note-id]");
          return owner instanceof HTMLElement ? owner.dataset.noteId : undefined;
        }

        function updateNoteViewDisplays(views) {
          const language = currentLanguage();

          for (const counter of document.querySelectorAll("[data-note-view-count]")) {
            if (!(counter instanceof HTMLElement)) {
              continue;
            }

            const noteId = noteIdForElement(counter);
            const count = noteId ? Number(views[noteId] ?? 0) : 0;
            counter.dataset.en = noteViewLabel(count, "en");
            counter.dataset.zh = noteViewLabel(count, "zh");
            counter.textContent = noteViewLabel(count, language);
          }
        }

        function sortNoteCardsByViews(views) {
          for (const container of document.querySelectorAll("[data-sort-notes-by-views]")) {
            const cards = Array.from(container.children).filter(
              (child) => child instanceof HTMLElement && child.matches("[data-note-card]")
            );

            cards.forEach((card, index) => {
              card.dataset.originalIndex ||= String(index);
            });

            cards
              .sort((left, right) => {
                const leftViews = Number(views[left.dataset.noteId ?? ""] ?? 0);
                const rightViews = Number(views[right.dataset.noteId ?? ""] ?? 0);

                if (leftViews !== rightViews) {
                  return rightViews - leftViews;
                }

                return Number(left.dataset.originalIndex ?? 0) - Number(right.dataset.originalIndex ?? 0);
              })
              .forEach((card) => container.append(card));
          }
        }

        // Fire-and-forget increment for the current note page. Returns the new
        // count so the caller can patch the local copy without a re-fetch.
        async function incrementCurrentNoteView() {
          const currentNote = document.querySelector("[data-note-view-root][data-note-id]");
          if (!(currentNote instanceof HTMLElement) || !currentNote.dataset.noteId) {
            return undefined;
          }
          const noteId = currentNote.dataset.noteId;
          // Only count once per browser session per note.
          if (alreadyViewed(noteId)) {
            return undefined;
          }
          markViewed(noteId);
          try {
            const res = await fetch(`${viewsApi}/increment`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id: noteId })
            });
            if (!res.ok) return undefined;
            const data = await res.json();
            return { noteId, count: Number(data.count) };
          } catch {
            return undefined;
          }
        }

        // Latest known counts, kept in memory so language toggles can repaint.
        let noteViews = {};

        applyLanguage(currentLanguage());
        applyTheme(currentTheme(), false);
        applyRgb(rgbOn(), false);

        // Load counts online, then repaint and sort. Increment runs in parallel.
        (async () => {
          const [counts, bump] = await Promise.all([
            fetchNoteViews(),
            incrementCurrentNoteView()
          ]);
          noteViews = counts && typeof counts === "object" ? counts : {};
          if (bump && Number.isFinite(bump.count)) {
            noteViews[bump.noteId] = bump.count;
          }
          updateNoteViewDisplays(noteViews);
          sortNoteCardsByViews(noteViews);
        })();

        for (const toggle of document.querySelectorAll("[data-language-toggle]")) {
          toggle.addEventListener("click", () => {
            applyLanguage(currentLanguage() === "zh" ? "en" : "zh");
            updateNoteViewDisplays(noteViews);
            applyTheme(currentTheme(), false);
            applyRgb(rgbOn(), false);
          });
        }

        for (const toggle of document.querySelectorAll("[data-theme-toggle]")) {
          toggle.addEventListener("click", () => {
            applyTheme(currentTheme() === "dark" ? "light" : "dark", true);
          });
        }

        for (const toggle of document.querySelectorAll("[data-rgb-toggle]")) {
          toggle.addEventListener("click", () => {
            applyRgb(!rgbOn(), true);
            // Emit the radiating colour ring from the button.
            toggle.classList.remove("burst");
            void toggle.offsetWidth; // reflow so the animation can replay
            toggle.classList.add("burst");
            setTimeout(() => toggle.classList.remove("burst"), 700);
          });
        }

        // Follow the system preference until the user makes an explicit choice.
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (event) => {
          if (localStorage.getItem(themeKey)) {
            return;
          }
          applyTheme(event.matches ? "dark" : "light", false);
        });
      })();
    </script>
  </body>
</html>
