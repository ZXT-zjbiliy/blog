---
import BaseLayout from "@layouts/BaseLayout.astro";
import IdentityMark from "@components/IdentityMark.astro";
import LanguageToggle from "@components/LanguageToggle.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { sitePath } from "@lib/site-data";

const { title, description } = Astro.props;

const links = [
  { href: "/", label: "Home", labelZh: "首页", short: "H" },
  { href: "/notes", label: "Notes", labelZh: "笔记", short: "N" },
  { href: "/projects", label: "Projects", labelZh: "项目", short: "P" },
  { href: "/topics", label: "Topics", labelZh: "主题", short: "T" },
  { href: "/about", label: "About", labelZh: "关于", short: "A" }
];
---

<BaseLayout title={title} description={description}>
  <div class="portal-shell" data-portal-shell data-collapsed-class="portal-shell collapsed">
    <aside class="sidebar">
      <div class="sidebar-head">
        <a class="portal-brand" href={sitePath("/")}>
          <IdentityMark compact />
          <span>ZXT Portal</span>
        </a>
        <button class="sidebar-toggle" type="button" data-sidebar-toggle aria-label="Collapse sidebar" title="Collapse sidebar">
          <span aria-hidden="true">‹</span>
        </button>
      </div>
      <nav aria-label="Portal navigation">
        {links.map((link) => (
          <a href={sitePath(link.href)} title={link.label}>
            <span class="nav-short" aria-hidden="true">{link.short}</span>
            <span class="nav-label" data-zh={link.labelZh}>{link.label}</span>
          </a>
        ))}
      </nav>
      <div class="sidebar-tools">
        <LanguageToggle />
        <ThemeToggle />
      </div>
    </aside>
    <main class="portal-main">
      <slot />
    </main>
  </div>
</BaseLayout>

<style>
  .portal-shell {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    min-height: 100vh;
    min-width: 0;
    transition: grid-template-columns 180ms ease;
  }

  .portal-shell.collapsed {
    grid-template-columns: 76px minmax(0, 1fr);
  }

  .sidebar {
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
    border-right: 1px solid color-mix(in srgb, var(--accent) 22%, var(--line));
    background: var(--surface);
    padding: 24px;
    box-shadow: 1px 0 16px -8px rgba(var(--accent-rgb), 0.5);
    transition:
      padding 180ms ease,
      background 180ms ease;
  }

  .sidebar-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    margin-bottom: 28px;
  }

  .portal-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    font-weight: 800;
  }

  .portal-brand span {
    white-space: nowrap;
  }

  .sidebar-toggle {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface-muted);
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1;
    transition: background var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .sidebar-toggle span {
    display: inline-block;
    transition: transform var(--dur-med) var(--ease);
  }

  .sidebar-toggle:hover {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .sidebar nav {
    display: grid;
    gap: 8px;
  }

  .sidebar nav a {
    display: flex;
    align-items: center;
    gap: 10px;
    border-radius: var(--radius);
    color: var(--muted);
    font-weight: 700;
    padding: 8px 10px;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .nav-short {
    display: none;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: var(--radius);
    background: var(--surface-muted);
    color: var(--accent-strong);
    font-size: 0.8rem;
    font-weight: 900;
  }

  .sidebar nav a:hover {
    background: color-mix(in srgb, var(--accent) 10%, var(--surface-muted));
    box-shadow: inset 2px 0 0 var(--accent), inset 0 0 12px -6px rgba(var(--accent-rgb), 0.8);
    color: var(--accent);
  }

  .sidebar-tools {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
  }

  .portal-shell.collapsed .sidebar {
    padding: 20px 14px;
  }

  .portal-shell.collapsed .portal-brand span,
  .portal-shell.collapsed .nav-label,
  .portal-shell.collapsed .sidebar-tools {
    display: none;
  }

  .portal-shell.collapsed .sidebar-head {
    justify-content: center;
    margin-bottom: 22px;
  }

  .portal-shell.collapsed .portal-brand {
    display: none;
  }

  .portal-shell.collapsed .sidebar-toggle span {
    transform: rotate(180deg);
  }

  .portal-shell.collapsed .sidebar nav a {
    justify-content: center;
    padding: 7px;
  }

  .portal-shell.collapsed .nav-short {
    display: grid;
  }

  .portal-main {
    width: min(1080px, calc(100% - 32px));
    min-width: 0;
    margin: 0 auto;
    padding: 36px 0 56px;
  }

  @media (max-width: 760px) {
    .portal-shell {
      grid-template-columns: 1fr;
    }

    .portal-shell.collapsed {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      height: auto;
      overflow: visible;
      border-right: 0;
      border-bottom: 1px solid var(--line);
    }

    .sidebar nav {
      display: flex;
      flex-wrap: wrap;
    }

    .sidebar-toggle {
      display: none;
    }

    .portal-shell.collapsed .portal-brand,
    .portal-shell.collapsed .portal-brand span,
    .portal-shell.collapsed .nav-label,
    .portal-shell.collapsed .sidebar-tools {
      display: inherit;
    }

    .portal-shell.collapsed .nav-short {
      display: none;
    }

    .portal-main {
      width: min(960px, calc(100vw - 32px));
    }
  }
</style>

<script>
  (() => {
    const key = "zxt-sidebar-collapsed";
    const shell = document.querySelector("[data-portal-shell]");
    const toggle = document.querySelector("[data-sidebar-toggle]");

    if (!(shell instanceof HTMLElement) || !(toggle instanceof HTMLButtonElement)) {
      return;
    }

    function applySidebarState(collapsed: boolean, shellElement: HTMLElement, toggleButton: HTMLButtonElement) {
      shellElement.classList.toggle("collapsed", collapsed);
      toggleButton.setAttribute("aria-expanded", String(!collapsed));
      toggleButton.setAttribute("aria-label", collapsed ? "Expand sidebar" : "Collapse sidebar");
      toggleButton.setAttribute("title", collapsed ? "Expand sidebar" : "Collapse sidebar");
      localStorage.setItem(key, collapsed ? "1" : "0");
    }

    applySidebarState(localStorage.getItem(key) === "1", shell, toggle);

    toggle.addEventListener("click", () => {
      applySidebarState(!shell.classList.contains("collapsed"), shell, toggle);
    });
  })();
</script>
