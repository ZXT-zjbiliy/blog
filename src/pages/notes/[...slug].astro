---
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import rehypeKatex from "rehype-katex";
import remarkMath from "remark-math";
import PortalLayout from "@layouts/PortalLayout.astro";
import Comments from "@components/Comments.astro";
import { entryZh } from "@lib/i18n";
import { getNoteSection, getNoteSections } from "@lib/note-sections";
import { formatDate, sitePath } from "@lib/site-data";

const markdownProcessor = await createMarkdownProcessor({
  remarkPlugins: [remarkMath],
  rehypePlugins: [[rehypeKatex, { strict: false, throwOnError: false }]]
});

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => data.draft !== true);
  return notes.flatMap((note) => {
    const sections = getNoteSections(note.body ?? "");
    const notePath = { params: { slug: note.id }, props: { note } };
    const sectionPaths = sections.map((section) => ({
      params: { slug: `${note.id}/${section.slug}` },
      props: { note, sectionSlug: section.slug }
    }));

    return [notePath, ...sectionPaths];
  });
}

type Props = {
  note: CollectionEntry<"notes">;
  sectionSlug?: string;
};

const { note, sectionSlug } = Astro.props as Props;
const noteBody = note.body ?? "";
const sections = getNoteSections(noteBody);
const currentSection = sectionSlug ? getNoteSection(noteBody, sectionSlug) : undefined;
const renderedSection = currentSection
  ? await markdownProcessor.render(currentSection.content, { frontmatter: note.data })
  : undefined;
let Content;
let wholeHeadings: { depth: number; slug: string; text: string }[] = [];

if (sections.length === 0) {
  const rendered = await render(note);
  Content = rendered.Content;
  wholeHeadings = (rendered.headings ?? []) as { depth: number; slug: string; text: string }[];
}

// Sub-headings (## and deeper) for the right-side mini table of contents.
const rawSubHeadings = currentSection
  ? ((renderedSection?.metadata.headings ?? []) as { depth: number; slug: string; text: string }[])
  : wholeHeadings;
const subHeadings = rawSubHeadings.filter((heading) => heading.depth >= 2 && heading.depth <= 4);

const zh = entryZh("notes", note.id);
const pageTitle = currentSection ? `${currentSection.title} | ${note.data.title}` : note.data.title;
---

<PortalLayout title={pageTitle} description={note.data.description}>
  <div
    class:list={[
      "note-layout",
      sections.length === 0 && "no-left",
      subHeadings.length === 0 && "no-right"
    ]}
    data-note-view-root
    data-note-id={note.id}
  >
    {sections.length > 0 ? (
      <aside class="note-toc note-side" data-note-side="left" aria-label="Note table of contents">
        <div class="note-side-head">
          <p class="eyebrow" data-zh="目录">Contents</p>
          <button
            class="side-toggle"
            type="button"
            data-side-toggle="left"
            aria-label="Collapse contents"
            title="Collapse contents"
          >
            <span aria-hidden="true">‹</span>
          </button>
        </div>
        <nav>
          {sections.map((section) => (
            <a
              class:list={[section.slug === sectionSlug && "active"]}
              href={sitePath(`/notes/${note.id}/${section.slug}`)}
            >
              <span>{section.index + 1}</span>
              {section.title}
            </a>
          ))}
        </nav>
      </aside>
    ) : null}

    <article class="prose note-article">
      <p class="eyebrow" data-zh={zh?.meta}>{note.data.category}</p>
      <h1 data-zh={zh?.title}>{note.data.title}</h1>
      <p class="muted" data-zh={zh?.description}>{note.data.description}</p>
      <p class="muted">
        <time datetime={note.data.date.toISOString()}>{formatDate(note.data.date)}</time>
        {note.data.updated && note.data.updated.getTime() !== note.data.date.getTime()
          ? <span data-zh={` 更新于 ${formatDate(note.data.updated)}`}> Updated {formatDate(note.data.updated)}</span>
          : null}
        <span data-note-view-count data-zh=""></span>
      </p>
      <ul class="tag-list">
        {note.data.tags.map((tag, index) => <li class="tag" data-zh={zh?.tags?.[index]}>{tag}</li>)}
      </ul>

      {currentSection ? (
        <div class="note-content" set:html={renderedSection?.code} />
      ) : sections.length > 0 ? (
        <section class="section-index">
          <h2 data-zh="章节目录">Section index</h2>
          <p class="muted" data-zh="从左侧目录选择一个章节阅读">
            Pick a section from the table of contents to read it as a separate page.
          </p>
        </section>
      ) : Content ? (
        <Content />
      ) : null}

      <Comments />
    </article>

    {subHeadings.length > 0 ? (
      <aside class="note-subtoc note-side" data-note-side="right" aria-label="Section outline">
        <div class="note-side-head">
          <p class="eyebrow" data-zh="小节">On this page</p>
          <button
            class="side-toggle"
            type="button"
            data-side-toggle="right"
            aria-label="Collapse outline"
            title="Collapse outline"
          >
            <span aria-hidden="true">›</span>
          </button>
        </div>
        <nav>
          {subHeadings.map((heading) => (
            <a class:list={[`depth-${heading.depth}`]} href={`#${heading.slug}`}>
              {heading.text}
            </a>
          ))}
        </nav>
      </aside>
    ) : null}
  </div>
</PortalLayout>

<style>
  .note-layout {
    --lw: minmax(180px, 220px);
    --rw: minmax(180px, 220px);
    display: grid;
    grid-template-columns: var(--lw) minmax(0, 1fr) var(--rw);
    gap: 28px;
    align-items: start;
    transition: grid-template-columns 180ms ease;
  }

  /* Collapsed side rails shrink to a slim strip so the note gets wider. */
  .note-layout.left-collapsed {
    --lw: 44px;
  }

  .note-layout.right-collapsed {
    --rw: 44px;
  }

  /* Missing side rails collapse their track. */
  .note-layout.no-left {
    grid-template-columns: minmax(0, 1fr) var(--rw);
  }

  .note-layout.no-right {
    grid-template-columns: var(--lw) minmax(0, 1fr);
  }

  .note-layout.no-left.no-right {
    grid-template-columns: 1fr;
  }

  .note-side {
    position: sticky;
    top: 24px;
    max-height: calc(100vh - 48px);
    min-width: 0;
    overflow: auto;
  }

  .note-toc {
    border-right: 1px solid var(--line);
    padding-right: 14px;
  }

  .note-subtoc {
    border-left: 1px solid var(--line);
    padding-left: 14px;
  }

  .note-side-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
  }

  .note-side-head .eyebrow {
    margin: 0;
  }

  .side-toggle {
    display: inline-grid;
    flex: 0 0 auto;
    place-items: center;
    width: 26px;
    height: 26px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface-muted);
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    font-weight: 900;
    line-height: 1;
    transition: background var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .side-toggle span {
    display: inline-block;
    transition: transform var(--dur-med) var(--ease);
  }

  .side-toggle:hover {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  .note-toc nav,
  .note-subtoc nav {
    display: grid;
    gap: 4px;
  }

  .note-toc a {
    display: grid;
    grid-template-columns: 22px minmax(0, 1fr);
    gap: 8px;
    align-items: start;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1.35;
    padding: 7px 8px;
    transition: background var(--dur-fast) var(--ease),
      border-left-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .note-toc a:hover {
    border-left-color: var(--accent);
    color: var(--accent-strong);
  }

  .note-toc a.active {
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    box-shadow: -1px 0 8px -2px color-mix(in srgb, var(--accent) 60%, transparent);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .note-toc span {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .note-subtoc a {
    display: block;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--muted);
    font-size: 0.86rem;
    line-height: 1.35;
    padding: 5px 8px;
    transition: background var(--dur-fast) var(--ease),
      border-left-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .note-subtoc a:hover {
    border-left-color: var(--accent);
    color: var(--accent-strong);
  }

  .note-subtoc a.active {
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    box-shadow: -1px 0 8px -2px color-mix(in srgb, var(--accent) 60%, transparent);
    color: var(--accent-strong);
    font-weight: 700;
  }

  .note-subtoc a.depth-3 {
    padding-left: 20px;
    font-size: 0.82rem;
  }

  .note-subtoc a.depth-4 {
    padding-left: 32px;
    font-size: 0.8rem;
  }

  /* Collapsed side rail: shrink to a slim strip that only shows the toggle. */
  .note-side.collapsed {
    overflow: visible;
  }

  .note-side.collapsed nav,
  .note-side.collapsed .eyebrow {
    display: none;
  }

  .note-side.collapsed .note-side-head {
    margin-bottom: 0;
    justify-content: center;
  }

  .note-toc.collapsed {
    padding-right: 6px;
  }

  .note-subtoc.collapsed {
    padding-left: 6px;
  }

  .note-side.collapsed .side-toggle span {
    transform: rotate(180deg);
    display: inline-block;
  }

  .note-article {
    max-width: 960px;
  }

  h1 {
    margin: var(--space-2) 0;
    font-size: var(--font-size-h1);
    line-height: var(--line-tight);
  }

  .section-index {
    margin-top: 28px;
    border-top: 1px solid var(--line);
    padding-top: 18px;
  }

  .note-content :global(h1) {
    margin-top: 34px;
    font-size: 2rem;
  }

  /* Offset anchor jumps so headings are not hidden under sticky UI. */
  .note-content :global(:is(h1, h2, h3, h4)) {
    scroll-margin-top: var(--space-8);
  }

  @media (max-width: 880px) {
    .note-layout,
    .note-layout.no-left,
    .note-layout.no-right {
      grid-template-columns: 1fr;
    }

    .note-side {
      position: static;
      max-height: none;
      overflow: visible;
    }

    .note-toc {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 14px;
    }

    .note-subtoc {
      order: 3;
      border-left: 0;
      border-top: 1px solid var(--line);
      padding-left: 0;
      padding-top: 14px;
    }

    .side-toggle {
      display: none;
    }
  }
</style>

<script>
  (() => {
    const root = document.querySelector("[data-note-view-root]");
    if (!(root instanceof HTMLElement)) {
      return;
    }

    // Persist collapse state per side, independent of the portal sidebar.
    const collapseKey = "zxt-note-side-collapsed";
    let state: Record<string, boolean> = {};
    try {
      state = JSON.parse(localStorage.getItem(collapseKey) ?? "{}") ?? {};
    } catch {
      state = {};
    }

    const toggles = root.querySelectorAll<HTMLButtonElement>("[data-side-toggle]");
    toggles.forEach((toggle) => {
      const side = toggle.getAttribute("data-side-toggle");
      if (!side) {
        return;
      }

      const panel = root.querySelector<HTMLElement>(`[data-note-side="${side}"]`);
      if (!panel) {
        return;
      }

      const apply = (collapsed: boolean) => {
        panel.classList.toggle("collapsed", collapsed);
        root.classList.toggle(`${side}-collapsed`, collapsed);
        toggle.setAttribute("aria-expanded", String(!collapsed));
        const label = collapsed ? "Expand" : "Collapse";
        toggle.setAttribute("aria-label", label);
        toggle.setAttribute("title", label);
      };

      apply(state[side] === true);

      toggle.addEventListener("click", () => {
        const collapsed = !panel.classList.contains("collapsed");
        apply(collapsed);
        state[side] = collapsed;
        try {
          localStorage.setItem(collapseKey, JSON.stringify(state));
        } catch {
          /* ignore storage errors */
        }
      });
    });

    // Scrollspy: highlight the sub-heading currently near the top of the viewport.
    const subLinks = Array.from(
      root.querySelectorAll<HTMLAnchorElement>('[data-note-side="right"] nav a')
    );
    if (subLinks.length > 0 && "IntersectionObserver" in window) {
      const linkById = new Map<string, HTMLAnchorElement>();
      const targets: HTMLElement[] = [];

      subLinks.forEach((link) => {
        const id = decodeURIComponent(link.getAttribute("href")?.slice(1) ?? "");
        const target = id ? document.getElementById(id) : null;
        if (target) {
          linkById.set(id, link);
          targets.push(target);
        }
      });

      const visible = new Set<string>();
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            const id = entry.target.id;
            if (entry.isIntersecting) {
              visible.add(id);
            } else {
              visible.delete(id);
            }
          }

          let activeId: string | undefined;
          for (const target of targets) {
            if (visible.has(target.id)) {
              activeId = target.id;
              break;
            }
          }

          subLinks.forEach((link) => link.classList.remove("active"));
          if (activeId) {
            linkById.get(activeId)?.classList.add("active");
          }
        },
        { rootMargin: "0px 0px -70% 0px", threshold: 0 }
      );

      targets.forEach((target) => observer.observe(target));
    }
  })();
</script>
