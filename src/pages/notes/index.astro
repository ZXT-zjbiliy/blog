---
import { getCollection } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import { entryZh, tagZh } from "@lib/i18n";
import { noteEntryPath } from "@lib/note-sections";
import { getAllTags, sortByDateDesc, visibleEntries } from "@lib/site-data";

const notes = sortByDateDesc(visibleEntries(await getCollection("notes")));
const tags = getAllTags(notes);
---

<PortalLayout title="Notes" description="Personal notes and engineering writing.">
  <section class="page-head">
    <p class="eyebrow" data-zh="知识库">Knowledge base</p>
    <h1 data-zh="笔记">Notes</h1>
    <p class="muted" data-zh="按分类、标签和日期搜索或浏览笔记。">
      Search and browse notes by category, tag, and date.
    </p>
    <input
      id="note-search"
      type="search"
      placeholder="Search notes, tags, or categories"
      data-placeholder-zh="搜索笔记、标签或分类"
    />
    <ul class="tag-list">
      {tags.map((tag) => <li class="tag" data-zh={tagZh(tag)}>{tag}</li>)}
    </ul>
  </section>

  <section class="grid" id="notes-list">
    {notes.map((note) => {
      const zh = entryZh("notes", note.id);
      const searchText = [
        note.data.title,
        note.data.description,
        note.data.category,
        note.data.tags.join(" "),
        zh?.title,
        zh?.description,
        zh?.meta,
        zh?.tags?.join(" ")
      ].filter(Boolean).join(" ").toLowerCase();

      return (
        <div data-search={searchText}>
          <ContentCard
            href={noteEntryPath(note.id, note.body)}
            noteId={note.id}
            title={note.data.title}
            titleZh={zh?.title}
            description={note.data.description}
            descriptionZh={zh?.description}
            date={note.data.date}
            tags={note.data.tags}
            tagsZh={zh?.tags}
            meta={note.data.category}
            metaZh={zh?.meta}
          />
        </div>
      );
    })}
  </section>

  <script>
    const input = document.querySelector("#note-search");
    const items = Array.from(document.querySelectorAll("#notes-list [data-search]"));

    if (input instanceof HTMLInputElement) {
      input.addEventListener("input", () => {
        const query = input.value.toLowerCase().trim();

        for (const item of items) {
          if (item instanceof HTMLElement) {
            const searchText = item.dataset.search ?? "";
            item.hidden = query.length > 0 && !searchText.includes(query);
          }
        }
      });
    }
  </script>
</PortalLayout>

<style>
  input {
    width: 100%;
    min-height: 44px;
    margin-top: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0 12px;
    font: inherit;
    transition: border-color var(--dur-fast) var(--ease),
      box-shadow var(--dur-fast) var(--ease);
  }

  input:focus-visible {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 20%, transparent);
  }
</style>
