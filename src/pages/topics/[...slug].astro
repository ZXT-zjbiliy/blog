---
import { getCollection, render } from "astro:content";
import ContentCard from "@components/ContentCard.astro";
import PortalLayout from "@layouts/PortalLayout.astro";
import { entryZh } from "@lib/i18n";
import { noteEntryPath } from "@lib/note-sections";
import { sortByDateDesc } from "@lib/site-data";

export async function getStaticPaths() {
  const topics = await getCollection("topics", ({ data }) => data.draft !== true);
  return topics.map((topic) => ({ params: { slug: topic.id }, props: { topic } }));
}

const { topic } = Astro.props;
const { Content } = await render(topic);
const zh = entryZh("topics", topic.id);
const noteIds = topic.data.notes.map((note) => note.id);
const projectIds = topic.data.projects.map((project) => project.id);
const notes = sortByDateDesc(
  await getCollection("notes", ({ id, data }) => data.draft !== true && noteIds.includes(id))
);
const projects = sortByDateDesc(
  await getCollection("projects", ({ id, data }) => data.draft !== true && projectIds.includes(id))
);
---

<PortalLayout title={topic.data.title} description={topic.data.description}>
  <article class="prose">
    <p class="eyebrow" data-zh="主题">Topic</p>
    <h1 data-zh={zh?.title}>{topic.data.title}</h1>
    <p class="muted" data-zh={zh?.description}>{topic.data.description}</p>
    <ul class="tag-list">
      {topic.data.tags.map((tag, index) => <li class="tag" data-zh={zh?.tags?.[index]}>{tag}</li>)}
    </ul>
    <Content />
  </article>

  {notes.length > 0 ? (
    <section class="related">
      <h2 data-zh="笔记">Notes</h2>
      <div class="grid">
        {notes.map((note) => {
          const noteZh = entryZh("notes", note.id);
          return (
            <ContentCard
              href={noteEntryPath(note.id, note.body)}
              noteId={note.id}
              title={note.data.title}
              titleZh={noteZh?.title}
              description={note.data.description}
              descriptionZh={noteZh?.description}
              date={note.data.date}
              tags={note.data.tags}
              tagsZh={noteZh?.tags}
              meta={note.data.category}
              metaZh={noteZh?.meta}
            />
          );
        })}
      </div>
    </section>
  ) : null}

  {projects.length > 0 ? (
    <section class="related">
      <h2 data-zh="项目">Projects</h2>
      <div class="grid">
        {projects.map((project) => {
          const projectZh = entryZh("projects", project.id);
          return (
            <ContentCard
              href={`/projects/${project.id}`}
              title={project.data.title}
              titleZh={projectZh?.title}
              description={project.data.description}
              descriptionZh={projectZh?.description}
              date={project.data.date}
              tags={project.data.stack}
              tagsZh={projectZh?.tags}
              meta={project.data.status}
              metaZh={projectZh?.meta}
            />
          );
        })}
      </div>
    </section>
  ) : null}
</PortalLayout>

<style>
  h1 {
    margin: 8px 0;
    font-size: 2.7rem;
    line-height: 1.05;
  }

  .related {
    margin-top: 36px;
  }
</style>
