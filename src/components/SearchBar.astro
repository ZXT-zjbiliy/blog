---
interface Props {
  searchIndexUrl: string;
  tokensUrl: string;
}

const { searchIndexUrl, tokensUrl } = Astro.props;
---

<div class="search-wrap" data-search-wrap data-search-index-url={searchIndexUrl} data-search-tokens-url={tokensUrl}>
  <div class="search-field" data-search-field>
    <span class="search-icon" aria-hidden="true">вҢ•</span>
    <div class="chip-row" data-search-chips></div>
    <input
      class="search-input"
      type="search"
      data-search-input
      placeholder="Search notes, projects, topicsвҖҰ"
      data-placeholder-zh="жҗңзҙўз¬”и®°гҖҒйЎ№зӣ®гҖҒдё»йўҳвҖҰвҖҰ"
      autocomplete="off"
      aria-label="Search site content"
      role="combobox"
      aria-expanded="false"
      aria-controls="search-dropdown"
      aria-autocomplete="list"
    />
    <button
      class="search-clear"
      type="button"
      data-search-clear
      hidden
      aria-label="Clear search"
      title="Clear search"
    >Г—</button>
    <button
      class="search-fulltext-btn"
      type="button"
      data-search-fulltext
      aria-pressed="false"
      data-zh="е…Ёж–Ү"
      title="Search inside note content"
    >Full text</button>
  </div>

  <div class="search-dropdown" id="search-dropdown" data-search-dropdown hidden>
    <div class="search-tag-panel" data-search-tag-panel>
      <p class="search-panel-label" data-zh="жҢүж ҮзӯҫзӯӣйҖү">Filter by tag</p>
      <div class="tag-marquee" data-search-all-tags></div>
    </div>
    <ul class="search-results" data-search-results role="listbox" aria-label="Search results" hidden></ul>
    <p class="search-empty" data-search-empty hidden data-zh="жІЎжңүжүҫеҲ°з»“жһң" role="status">No results found</p>
    <p class="search-loading" data-search-loading hidden data-zh="жӯЈеңЁеҠ иҪҪе…Ёж–Үзҙўеј•вҖҰ" role="status">Loading full-text indexвҖҰ</p>
  </div>
</div>

<style>
  .search-wrap {
    position: relative;
    margin: var(--space-6) 0 var(--space-4);
  }

  .search-field {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--surface);
    padding: 8px 10px;
    transition: border-color var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }

  .search-field:focus-within {
    border-color: var(--accent);
    box-shadow: var(--glow-soft);
  }

  .search-icon {
    color: var(--accent-strong);
    font-size: 1.15rem;
    line-height: 1;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .chip-row:empty {
    display: none;
  }

  .search-input {
    flex: 1 1 180px;
    min-width: 120px;
    border: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    font-size: var(--font-size-body);
    padding: 4px 2px;
    outline: none;
  }

  .search-clear {
    flex: 0 0 auto;
    display: inline-grid;
    place-items: center;
    width: 24px;
    height: 24px;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--surface-muted);
    color: var(--muted);
    cursor: pointer;
    font: inherit;
    font-size: 1.1rem;
    line-height: 1;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .search-clear[hidden] { display: none; }

  .search-clear:hover {
    background: color-mix(in srgb, var(--accent) 16%, var(--surface-muted));
    color: var(--accent);
  }

  .search-fulltext-btn {
    flex: 0 0 auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: var(--surface-muted);
    color: var(--accent-strong);
    cursor: pointer;
    font: inherit;
    font-size: var(--font-size-sm);
    font-weight: 700;
    padding: 5px 12px;
    transition: background var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .search-fulltext-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .search-fulltext-btn[aria-pressed="true"] {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
    box-shadow: var(--glow-soft);
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    border: 1px solid var(--accent);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--accent) 28%, var(--surface-muted));
    color: var(--accent-strong);
    font-size: var(--font-size-sm);
    font-weight: 600;
    padding: 3px 8px;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .chip button {
    display: inline-flex;
    align-items: center;
    border: 0;
    background: transparent;
    color: color-mix(in srgb, var(--accent-strong) 70%, transparent);
    cursor: pointer;
    font: inherit;
    font-size: 1rem;
    line-height: 1;
    padding: 0 1px;
    transition: color var(--dur-fast) var(--ease);
  }

  .chip button:hover {
    color: var(--accent);
  }

  .search-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    z-index: 100;
    border: 1px solid var(--line);
    border-top: 2px solid var(--accent);
    border-radius: var(--radius);
    background: var(--surface);
    box-shadow: var(--shadow-md);
    padding: 14px;
    max-height: min(60vh, 460px);
    overflow-y: auto;
  }

  .search-dropdown[hidden] {
    display: none;
  }

  .search-panel-label {
    margin: 0 0 8px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Single-row auto-scrolling tag marquee */
  .tag-marquee {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }

  :global(.tag-track) {
    display: flex;
    width: max-content;
    animation: tag-scroll 26s linear infinite;
  }

  .tag-marquee:hover :global(.tag-track) {
    animation-play-state: paused;
  }

  /* Touch devices have no hover: keep the row static & scrollable so tags are
     tappable instead of gliding away under the finger. */
  @media (hover: none) {
    .tag-marquee {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
    :global(.tag-track) {
      animation: none;
    }
  }

  :global(.tag-track ul) {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    padding: 0 8px 0 0;
    margin: 0;
    list-style: none;
  }

  @keyframes tag-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.tag-track) {
      animation: none;
    }
    .tag-marquee {
      overflow-x: auto;
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  /* Tag pills in the tag panel are clickable */
  [data-search-all-tags] .tag {
    cursor: pointer;
    transition: background var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  [data-search-all-tags] .tag:hover {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 12%, var(--surface-muted));
    color: var(--accent);
  }

  [data-search-all-tags] .tag.active-tag {
    border-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 18%, var(--surface-muted));
    color: var(--accent-strong);
    font-weight: 700;
  }

  /* Results list */
  .search-results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2px;
  }

  .search-results[hidden] { display: none; }

  .search-results li a {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    border-left: 2px solid transparent;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    padding: 9px 10px;
    color: inherit;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease),
      border-left-color var(--dur-fast) var(--ease);
  }

  .search-results li a:hover,
  .search-results li a:focus,
  .search-results li.kb-active a {
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, var(--surface));
  }

  .result-badge {
    flex: 0 0 auto;
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    background: var(--surface-muted);
    color: var(--accent-strong);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    margin-top: 3px;
    margin-right: 2px;
    text-transform: uppercase;
  }

  /* TOPIC results stand out: filled badge + accent left rail + tinted row */
  .result-badge.topic-badge {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
  }

  .result-item.topic a {
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, var(--surface));
  }

  .result-snippet {
    margin-top: 3px;
    color: var(--muted);
    font-size: var(--font-size-sm);
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  :global(.search-results mark) {
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    color: inherit;
    border-radius: 3px;
    padding: 0 1px;
  }

  .result-body {
    flex: 1;
    min-width: 0;
  }

  .result-title {
    display: block;
    color: var(--text);
    font-weight: 700;
    font-size: var(--font-size-body);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .result-desc {
    display: block;
    color: var(--muted);
    font-size: var(--font-size-sm);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-top: 2px;
  }

  .search-empty,
  .search-loading {
    margin: 8px 0 0;
    color: var(--muted);
    font-size: var(--font-size-sm);
  }

  .search-empty[hidden],
  .search-loading[hidden] { display: none; }
</style>
<script>
(() => {
  // в”Җв”Җ Types в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  interface SearchEntry {
    id: string;
    type: "note" | "project" | "topic";
    title: string;
    titleZh?: string;
    description: string;
    descriptionZh?: string;
    url: string;
    tags: string[];
    tagsZh: string[];
    category?: string;
    date: string;
  }
  // Lightweight index (loaded on first dropdown open)
  interface SearchIndex {
    entries: SearchEntry[];
    tags: { en: string; zh: string }[];
  }
  // Heavy tokens index (loaded only when user clicks "Full text")
  interface TokensIndex {
    tokens: Record<string, number[]>;
    texts: string[];  // plain-text note bodies, aligned with entries[] index
  }

  // в”Җв”Җ DOM refs в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  const wrap = document.querySelector<HTMLElement>("[data-search-wrap]");
  if (!wrap) return;

  const indexUrl = wrap.dataset.searchIndexUrl ?? "";
  const tokensUrl = wrap.dataset.searchTokensUrl ?? "";
  const inputEl = wrap.querySelector<HTMLInputElement>("[data-search-input]")!;
  const chipsEl = wrap.querySelector<HTMLElement>("[data-search-chips]")!;
  const fulltextBtn = wrap.querySelector<HTMLButtonElement>("[data-search-fulltext]")!;
  const dropdownEl = wrap.querySelector<HTMLElement>("[data-search-dropdown]")!;
  const tagPanelEl = wrap.querySelector<HTMLElement>("[data-search-tag-panel]")!;
  const allTagsEl = wrap.querySelector<HTMLElement>("[data-search-all-tags]")!;
  const resultsEl = wrap.querySelector<HTMLElement>("[data-search-results]")!;
  const emptyEl = wrap.querySelector<HTMLElement>("[data-search-empty]")!;
  const loadingEl = wrap.querySelector<HTMLElement>("[data-search-loading]")!;
  const clearBtn = wrap.querySelector<HTMLButtonElement>("[data-search-clear]")!;

  // в”Җв”Җ State в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  let indexData: SearchIndex | null = null;   // lightweight вҖ” loaded on first open
  let tokensData: TokensIndex | null = null;  // heavy вҖ” loaded only on fulltext click
  let indexLoading = false;
  let tokensLoading = false;
  let activeQuery = "";
  let activeTagFilters: string[] = [];  // English tag/stack values
  let fulltextMode = false;
  let kbIndex = -1;  // keyboard-highlighted result row (-1 = none)

  // в”Җв”Җ Language helper в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function isZh(): boolean {
    return document.documentElement.dataset.lang === "zh";
  }

  function localText(en: string, zh?: string): string {
    return isZh() && zh ? zh : en;
  }

  // в”Җв”Җ Highlight & snippet helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function escapeHtml(s: string): string {
    return s.replace(/[&<>"]/g, (c) =>
      c === "&" ? "&amp;" : c === "<" ? "&lt;" : c === ">" ? "&gt;" : "&quot;");
  }

  function escapeRegExp(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
  }

  // Escape text, then wrap query matches (full string + each word) in <mark>.
  function highlight(text: string, q: string): string {
    const escaped = escapeHtml(text);
    const terms = [q.trim(), ...q.trim().split(/\s+/)]
      .filter((t) => t.length >= 1)
      .map(escapeRegExp);
    if (terms.length === 0) return escaped;
    const re = new RegExp(`(${[...new Set(terms)].join("|")})`, "gi");
    return escaped.replace(re, "<mark>$1</mark>");
  }

  // Extract a ~40-char window around the first query hit in the plain body.
  function makeSnippet(text: string, q: string): string {
    if (!text) return "";
    const needle = q.trim().split(/\s+/)[0] ?? q.trim();
    if (!needle) return "";
    const pos = text.toLowerCase().indexOf(needle.toLowerCase());
    if (pos === -1) return "";
    const start = Math.max(0, pos - 40);
    const end = Math.min(text.length, pos + needle.length + 40);
    let snippet = text.slice(start, end);
    if (start > 0) snippet = "вҖҰ" + snippet;
    if (end < text.length) snippet = snippet + "вҖҰ";
    return highlight(snippet, q);
  }

  // в”Җв”Җ Dropdown open / close в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function openDropdown() {
    dropdownEl.hidden = false;
    inputEl.setAttribute("aria-expanded", "true");
    refreshDropdownContent();
  }

  function closeDropdown() {
    dropdownEl.hidden = true;
    inputEl.setAttribute("aria-expanded", "false");
    kbIndex = -1;
  }

  // в”Җв”Җ Tag panel в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  // Build one <ul> of tag pills. The decorative clone (ariaHidden) has no
  // event listeners and is skipped by assistive tech / keyboard tabbing.
  function buildTagUl(ariaHidden: boolean): HTMLUListElement {
    const ul = document.createElement("ul");
    if (ariaHidden) ul.setAttribute("aria-hidden", "true");
    for (const tag of indexData!.tags) {
      const li = document.createElement("li");
      li.className = "tag" + (activeTagFilters.includes(tag.en) ? " active-tag" : "");
      li.textContent = localText(tag.en, tag.zh);
      li.dataset.en = tag.en;
      li.dataset.zh = tag.zh;
      li.dataset.tagEn = tag.en;
      if (!ariaHidden) {
        li.setAttribute("role", "button");
        li.setAttribute("tabindex", "0");
        li.addEventListener("click", () => toggleTag(tag.en, tag.zh));
        li.addEventListener("keydown", (e) => { if (e.key === "Enter" || e.key === " ") { e.preventDefault(); toggleTag(tag.en, tag.zh); }});
      }
      ul.appendChild(li);
    }
    return ul;
  }

  function renderTagPanel() {
    if (!indexData) return;
    allTagsEl.innerHTML = "";
    const track = document.createElement("div");
    track.className = "tag-track";
    track.appendChild(buildTagUl(false)); // interactive copy
    track.appendChild(buildTagUl(true));  // decorative copy for seamless loop
    allTagsEl.appendChild(track);
  }

  function toggleTag(en: string, zh: string) {
    if (activeTagFilters.includes(en)) {
      removeTagFilter(en);
    } else {
      addTagFilter(en);
    }
  }

  // в”Җв”Җ Chips в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function addTagFilter(en: string) {
    if (activeTagFilters.includes(en)) return;
    activeTagFilters.push(en);
    renderChips();
    updateClearButton();
    search();
    // Update tag pill state
    allTagsEl.querySelectorAll<HTMLElement>("[data-tag-en]").forEach((el) => {
      el.classList.toggle("active-tag", el.dataset.tagEn === en || activeTagFilters.includes(el.dataset.tagEn ?? ""));
    });
  }

  function removeTagFilter(en: string) {
    activeTagFilters = activeTagFilters.filter((t) => t !== en);
    renderChips();
    updateClearButton();
    search();
    allTagsEl.querySelectorAll<HTMLElement>("[data-tag-en]").forEach((el) => {
      el.classList.toggle("active-tag", activeTagFilters.includes(el.dataset.tagEn ?? ""));
    });
  }

  function renderChips() {
    chipsEl.innerHTML = "";
    for (const en of activeTagFilters) {
      const zh = indexData?.tags.find((t) => t.en === en)?.zh ?? en;
      const chip = document.createElement("span");
      chip.className = "chip";
      chip.dataset.tag = en;

      const label = document.createElement("span");
      label.textContent = localText(en, zh);
      label.dataset.en = en;
      label.dataset.zh = zh;

      const removeBtn = document.createElement("button");
      removeBtn.type = "button";
      removeBtn.textContent = "Г—";
      removeBtn.setAttribute("aria-label", `Remove filter: ${en}`);
      removeBtn.addEventListener("click", (e) => { e.stopPropagation(); removeTagFilter(en); });

      chip.appendChild(label);
      chip.appendChild(removeBtn);
      chipsEl.appendChild(chip);
    }
  }

  // в”Җв”Җ Results в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function renderResults(matched: SearchEntry[]) {
    resultsEl.innerHTML = "";
    kbIndex = -1;  // reset keyboard highlight whenever results change
    if (matched.length === 0) {
      resultsEl.hidden = true;
      emptyEl.hidden = false;
      return;
    }
    emptyEl.hidden = true;
    resultsEl.hidden = false;

    const q = activeQuery.trim();
    matched.slice(0, 20).forEach((entry, i) => {
      const li = document.createElement("li");
      li.className = "result-item " + entry.type;
      li.id = `search-result-${i}`;
      li.setAttribute("role", "option");
      const a = document.createElement("a");
      a.href = entry.url;

      const badge = document.createElement("span");
      badge.className = "result-badge" + (entry.type === "topic" ? " topic-badge" : "");
      badge.textContent = entry.type.toUpperCase();

      const body = document.createElement("span");
      body.className = "result-body";

      const titleText = localText(entry.title, entry.titleZh);
      const titleSpan = document.createElement("span");
      titleSpan.className = "result-title";
      titleSpan.innerHTML = q ? highlight(titleText, q) : escapeHtml(titleText);
      if (entry.titleZh) {
        titleSpan.dataset.en = entry.title;
        titleSpan.dataset.zh = entry.titleZh;
      }

      const descText = localText(entry.description, entry.descriptionZh);
      const descSpan = document.createElement("span");
      descSpan.className = "result-desc";
      descSpan.innerHTML = q ? highlight(descText, q) : escapeHtml(descText);
      if (entry.descriptionZh) {
        descSpan.dataset.en = entry.description;
        descSpan.dataset.zh = entry.descriptionZh;
      }

      body.appendChild(titleSpan);
      body.appendChild(descSpan);

      // Full-text mode: show a highlighted body snippet around the first hit.
      if (fulltextMode && tokensData && q) {
        const idx = indexData!.entries.indexOf(entry);
        const snippetHtml = idx >= 0 ? makeSnippet(tokensData.texts[idx] ?? "", q) : "";
        if (snippetHtml) {
          const snip = document.createElement("span");
          snip.className = "result-snippet";
          snip.innerHTML = snippetHtml;
          body.appendChild(snip);
        }
      }

      a.appendChild(badge);
      a.appendChild(body);
      li.appendChild(a);
      resultsEl.appendChild(li);
    });
  }

  // в”Җв”Җ Keyboard navigation over the result rows в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function resultRows(): HTMLLIElement[] {
    return Array.from(resultsEl.querySelectorAll<HTMLLIElement>("li.result-item"));
  }

  function setKbActive(next: number) {
    const rows = resultRows();
    if (rows.length === 0) return;
    // Wrap around
    kbIndex = (next + rows.length) % rows.length;
    rows.forEach((row, i) => row.classList.toggle("kb-active", i === kbIndex));
    const active = rows[kbIndex];
    active.scrollIntoView({ block: "nearest" });
    inputEl.setAttribute("aria-activedescendant", active.id);
  }

  function openKbActive(): boolean {
    const rows = resultRows();
    if (kbIndex < 0 || kbIndex >= rows.length) return false;
    const link = rows[kbIndex].querySelector("a");
    if (link) { window.location.href = (link as HTMLAnchorElement).href; return true; }
    return false;
  }

  // в”Җв”Җ Search logic в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function metadataMatch(entry: SearchEntry, q: string): boolean {
    if (!q) return true;
    const haystack = [
      entry.title, entry.titleZh ?? "",
      entry.description, entry.descriptionZh ?? "",
      entry.tags.join(" "), entry.tagsZh.join(" "),
      entry.category ?? ""
    ].join(" ").toLowerCase();
    return haystack.includes(q.toLowerCase());
  }

  // Mirror the build-time tokeniser: ASCII words (вүҘ2 chars) + CJK bigrams.
  const CJK_RE = /[гҗҖ-йҝҝгҒҖ-гғҝк°Җ-нһҜиұҲ-п«ҝ]/;

  function queryTokens(q: string): string[] {
    const result = new Set<string>();
    const raw = q.toLowerCase().split(/[\s\t\n\r!"#%&'()*+,\-./:;<=>?@[\\\]^_`{|}~гҖӮпјҢгҖҒпјӣпјҡпјҹпјҒвҖҰвҖ”гҖҠгҖӢгҖҢгҖҚгҖҗгҖ‘гҖҖ]+/);
    for (const word of raw) {
      if (!word) continue;
      if (CJK_RE.test(word)) {
        const chars = [...word];
        if (chars.length === 1) {
          result.add(chars[0]);
          continue;
        }
        for (let i = 0; i < chars.length - 1; i++) {
          if (CJK_RE.test(chars[i]) && CJK_RE.test(chars[i + 1])) {
            result.add(chars[i] + chars[i + 1]);
          }
        }
      } else if (word.length >= 2) {
        result.add(word);
      }
    }
    return [...result];
  }

  function fulltextMatch(entry: SearchEntry, q: string, entryIdx: number): boolean {
    if (!q.trim() || !tokensData) return true;
    const tokens = queryTokens(q);
    if (tokens.length === 0) return metadataMatch(entry, q);
    if (entryIdx === -1) return false;
    return tokens.every((tok) => {
      const hits = tokensData!.tokens[tok];
      return hits ? hits.includes(entryIdx) : false;
    });
  }

  function tagMatch(entry: SearchEntry): boolean {
    if (activeTagFilters.length === 0) return true;
    return activeTagFilters.every((t) => entry.tags.includes(t));
  }

  function search() {
    // Index loads on first dropdown open; nothing to search until then.
    if (!indexData) return;

    const q = activeQuery.trim();
    const hasQuery = q.length > 0;
    const hasTags = activeTagFilters.length > 0;

    // Show tag panel only when nothing is typed and no tags active
    tagPanelEl.hidden = hasQuery || hasTags;

    if (!hasQuery && !hasTags) {
      resultsEl.hidden = true;
      emptyEl.hidden = true;
      tagPanelEl.hidden = false;
      return;
    }

    let candidates = indexData.entries;

    // Tag filter first (cheap)
    if (hasTags) {
      candidates = candidates.filter(tagMatch);
    }

    // Text filter вҖ” fulltext only if the tokens index actually loaded,
    // otherwise fall back to metadata match so results aren't all-or-nothing.
    if (hasQuery) {
      if (fulltextMode && tokensData) {
        candidates = candidates.filter((e) => fulltextMatch(e, q, indexData!.entries.indexOf(e)));
      } else {
        candidates = candidates.filter((e) => metadataMatch(e, q));
      }
    }

    renderResults(candidates);
  }

  // в”Җв”Җ Fetch lightweight index (entries + tags) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  async function fetchIndex(): Promise<void> {
    if (indexData || indexLoading) return;
    indexLoading = true;
    try {
      const res = await fetch(indexUrl);
      indexData = await res.json() as SearchIndex;
      renderTagPanel();
    } catch {
      // Silently fail вҖ” search degrades gracefully
    } finally {
      indexLoading = false;
    }
  }

  // в”Җв”Җ Fetch heavy tokens index (only on "Full text" click) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  async function fetchTokens(): Promise<void> {
    if (tokensData || tokensLoading) return;
    tokensLoading = true;
    loadingEl.hidden = false;
    try {
      const res = await fetch(tokensUrl);
      tokensData = await res.json() as TokensIndex;
    } catch {
      // Silently fail вҖ” fulltext search won't work but metadata search still does
    } finally {
      tokensLoading = false;
      loadingEl.hidden = true;
    }
  }

  // в”Җв”Җ Dropdown content refresh в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  function refreshDropdownContent() {
    if (!indexData) {
      // Load lightweight index on first open (no loading indicator вҖ” should be fast)
      fetchIndex().then(() => {
        search();
        renderTagPanel();
      });
      return;
    }
    search();
    if (!activeQuery && activeTagFilters.length === 0) {
      renderTagPanel();
    }
  }

  // Clear button is shown whenever there's a query or any active tag filters.
  function updateClearButton() {
    clearBtn.hidden = activeQuery.trim() === "" && activeTagFilters.length === 0;
  }

  function clearAll() {
    activeQuery = "";
    inputEl.value = "";
    activeTagFilters = [];
    renderChips();
    updateClearButton();
    search();
    renderTagPanel();
    inputEl.focus();
  }

  // в”Җв”Җ Events в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  inputEl.addEventListener("focus", () => openDropdown());

  inputEl.addEventListener("input", () => {
    activeQuery = inputEl.value;
    updateClearButton();
    openDropdown();
    search();
  });

  // Keyboard navigation over results
  inputEl.addEventListener("keydown", (e) => {
    if (e.key === "ArrowDown") {
      e.preventDefault();
      if (dropdownEl.hidden) openDropdown();
      setKbActive(kbIndex + 1);
    } else if (e.key === "ArrowUp") {
      e.preventDefault();
      setKbActive(kbIndex - 1);
    } else if (e.key === "Enter") {
      if (openKbActive()) e.preventDefault();
    }
  });

  clearBtn.addEventListener("click", () => clearAll());

  fulltextBtn.addEventListener("click", async () => {
    fulltextMode = !fulltextMode;
    fulltextBtn.setAttribute("aria-pressed", String(fulltextMode));
    if (fulltextMode && !tokensData) {
      await fetchTokens();  // Only now do we show the loading indicator + fetch
    }
    search();
    openDropdown();
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (!wrap.contains(e.target as Node)) closeDropdown();
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      closeDropdown();
      inputEl.blur();
    }
  });
})();
</script>
