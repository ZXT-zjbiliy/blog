---
import IdentityMark from "@components/IdentityMark.astro";
import LanguageToggle from "@components/LanguageToggle.astro";
import ThemeToggle from "@components/ThemeToggle.astro";
import { sitePath } from "@lib/site-data";

const links = [
  { href: "/notes", label: "Notes", labelZh: "笔记" },
  { href: "/projects", label: "Projects", labelZh: "项目" },
  { href: "/about", label: "About", labelZh: "关于" }
];

const contacts = [
  { href: "https://github.com/ZXT-zjbiliy", label: "GitHub", labelZh: "GitHub" },
  { href: "mailto:xt.zhang@zju.edu.cn", label: "xt.zhang@zju.edu.cn", labelZh: "xt.zhang@zju.edu.cn" }
];
---

<header class="site-header">
  <a class="brand" href={sitePath("/")}>
    <IdentityMark compact />
    <span>ZXT</span>
  </a>
  <div class="header-actions">
    <nav aria-label="Primary navigation">
      {links.map((link) => <a href={sitePath(link.href)} data-zh={link.labelZh}>{link.label}</a>)}
    </nav>
    <div class="contact-actions" aria-label="Contact links">
      {contacts.map((contact) => (
        <a class="contact-link" href={contact.href} data-zh={contact.labelZh}>{contact.label}</a>
      ))}
    </div>
    <LanguageToggle />
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 72px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--muted);
    font-weight: 700;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .contact-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    border: 1px solid color-mix(in srgb, var(--accent) 28%, var(--line));
    border-radius: var(--radius-pill);
    background: color-mix(in srgb, var(--surface) 88%, var(--accent) 12%);
    color: var(--accent-strong);
    font-size: 0.86rem;
    font-weight: 800;
    padding: 0 12px;
    transition: background var(--dur-fast) var(--ease),
      border-color var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  .contact-link:hover {
    border-color: var(--accent);
    background: var(--accent);
    color: white;
  }

  @media (max-width: 640px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      padding: 10px 0;
    }

    .header-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
