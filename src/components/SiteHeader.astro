---
import IdentityMark from "@components/IdentityMark.astro";
import LanguageToggle from "@components/LanguageToggle.astro";
import { sitePath } from "@lib/site-data";

const links = [
  { href: "/notes", label: "Notes", labelZh: "笔记" },
  { href: "/projects", label: "Projects", labelZh: "项目" },
  { href: "/about", label: "About", labelZh: "关于" }
];
---

<header class="site-header">
  <a class="brand" href={sitePath("/")}>
    <IdentityMark compact />
    <span>ZXT</span>
  </a>
  <div class="header-actions">
    <nav aria-label="Primary navigation">
      {links.map((link) => <a href={sitePath(link.href)} data-zh={link.labelZh}>{link.label}</a>)}
    </nav>
    <LanguageToggle />
  </div>
</header>

<style>
  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    min-height: 72px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    color: var(--muted);
    font-weight: 700;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  @media (max-width: 640px) {
    .site-header {
      align-items: flex-start;
      flex-direction: column;
      padding: 10px 0;
    }

    .header-actions {
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
    }
  }
</style>
