---
import { formatDate, sitePath } from "@lib/site-data";

interface Props {
  href: string;
  title: string;
  description: string;
  date?: Date;
  tags?: string[];
  meta?: string;
  titleZh?: string;
  descriptionZh?: string;
  tagsZh?: string[];
  metaZh?: string;
  noteId?: string;
}

const {
  href,
  title,
  description,
  date,
  tags = [],
  meta = "",
  titleZh,
  descriptionZh,
  tagsZh = [],
  metaZh,
  noteId
} = Astro.props;
---

<article class="card content-card" data-note-card={noteId} data-note-id={noteId}>
  <div class="meta">
    {date ? <time datetime={date.toISOString()}>{formatDate(date)}</time> : null}
    {meta ? <span data-zh={metaZh}>{meta}</span> : null}
    {noteId ? <span class="view-count" data-note-view-count data-zh="0 次点击">0 views</span> : null}
  </div>
  <h3><a href={sitePath(href)} data-zh={titleZh}>{title}</a></h3>
  <p data-zh={descriptionZh}>{description}</p>
  {tags.length > 0 ? (
    <ul class="tag-list">
      {tags.map((tag: string, index: number) => <li class="tag" data-zh={tagsZh[index]}>{tag}</li>)}
    </ul>
  ) : null}
</article>

<style>
  .content-card h3 {
    margin: 8px 0;
    line-height: 1.25;
  }

  .content-card p {
    margin: 0;
    color: var(--muted);
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    color: var(--muted);
    font-size: 0.86rem;
  }
</style>
